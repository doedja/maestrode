#!/usr/bin/env bash
# maestrode: shim that lets a smart model orchestrate a cheap one for code work.
#
# Reads from any OpenAI-compatible Chat Completions endpoint. Defaults are
# tuned for DeepSeek V4 Flash, but it works against OpenRouter, OmniRoute,
# OpenCode Zen, ollama, lmstudio, or the official DeepSeek API.
#
# usage:
#   maestrode "prompt"
#   echo "context" | maestrode "task"
#   maestrode -f a.py -f b.py "refactor both"
#   maestrode --files out/ "spec... write files as <<<FILE: path >>> ... <<<END FILE>>> blocks"
#   maestrode --session arm-b --system "You are a senior engineer." "follow-up turn"
#   maestrode --full "include reasoning trace"
#   maestrode --model gpt-5.1-codex "swap model"
#   maestrode gain                 show aggregate usage stats from the local log
#
# flags:
#   --session NAME    persist multi-turn at ~/.config/maestrode/sessions/NAME.json
#   --system TEXT     system prompt
#   --files DIR       parse <<<FILE: path >>> ... <<<END FILE>>> blocks, write each under DIR
#   -f|--file PATH    attach file contents as user context (repeatable)
#   --model ID        override MAESTRODE_MODEL
#   --max-tokens N    override max_tokens
#   --reasoning-effort LEVEL   low|medium|high|max (provider-dependent)
#   --thinking-budget N        enables thinking with budget_tokens=N
#   --full            also print reasoning_content
#   --raw             skip auto fence/dash sanitization
#   --dry-run         print payload size estimate, no API call
#   --warmup          send a small priming call first to crystallize KV-cache prefix
#                     (use on a fresh --session before the first real call)
#
# escalation contract (NEEDS_SMART):
#   the muscle can self-report when a brief is too vague or a task exceeds
#   its capability by emitting `<<<NEEDS_SMART>>>` or `<<<NEEDS_SMART: reason>>>`
#   as the first non-empty line of its response. maestrode exits 5 and prints
#   the rationale to stderr. session log + --files writes are skipped so the
#   brain can rerun the turn directly without polluting state.
#   teach the muscle about this contract via --system, e.g.:
#     --system "if the brief is ambiguous or the task exceeds your capability,
#               emit <<<NEEDS_SMART: short reason>>> as line 1 and stop."
#
# env (from ~/.config/maestrode/env or shell):
#   MAESTRODE_API_KEY        required
#   MAESTRODE_MODEL          default: deepseek-v4-flash
#   MAESTRODE_MAX_TOKENS     default: 65536 (raise if your endpoint allows more)
#   MAESTRODE_ENDPOINT       default: https://api.deepseek.com/v1/chat/completions
#   MAESTRODE_CURL_TIMEOUT   default: 600 (seconds)
#   MAESTRODE_ALLOW_SECRETS  set to 1 to bypass the secret-pattern scan
#
# exit codes:
#   0 ok, 1 transport error, 2 api error, 3 rate limit (429),
#   4 --files parse: no blocks found, 5 muscle escalated (NEEDS_SMART),
#   64 usage, 65 secrets detected, 66 file not found

set -euo pipefail

CONFIG_DIR="${MAESTRODE_CONFIG_DIR:-${HOME}/.config/maestrode}"
ENV_FILE="${CONFIG_DIR}/env"
USAGE_LOG="${CONFIG_DIR}/usage.jsonl"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

# Subcommand: `maestrode gain` prints aggregate stats from the usage log.
# No API key needed for this path.
if [[ "${1:-}" == "gain" ]]; then
  shift
  USAGE_LOG="$USAGE_LOG" python3 - "$@" <<'PY'
import json, os, sys, datetime, pathlib

log = pathlib.Path(os.environ["USAGE_LOG"])
if not log.exists() or log.stat().st_size == 0:
    print("maestrode gain: no usage logged yet at", log)
    print("(usage logs are appended after each successful call)")
    sys.exit(0)

rows = []
for line in log.read_text().splitlines():
    line = line.strip()
    if not line:
        continue
    try:
        rows.append(json.loads(line))
    except json.JSONDecodeError:
        continue

if not rows:
    print("maestrode gain: usage log exists but no valid entries")
    sys.exit(0)

def human(n: int) -> str:
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.0f}k"
    return str(n)

def hms(s: float) -> str:
    s = int(s)
    if s < 60:
        return f"{s}s"
    m, s = divmod(s, 60)
    if m < 60:
        return f"{m}m {s:02d}s"
    h, m = divmod(m, 60)
    return f"{h}h {m:02d}m {s:02d}s"

first_ts = min(r.get("ts", "") for r in rows if r.get("ts"))
last_ts  = max(r.get("ts", "") for r in rows if r.get("ts"))
def parse_ts(s):
    try:
        return datetime.datetime.fromisoformat(s)
    except Exception:
        return None
first_dt, last_dt = parse_ts(first_ts), parse_ts(last_ts)
span_days = ""
if first_dt and last_dt:
    days = max(1, (last_dt - first_dt).days + 1)
    span_days = f" ({days} day{'s' if days != 1 else ''})"

total_calls = len(rows)
total_prompt = sum(r.get("prompt", 0) for r in rows)
total_out    = sum(r.get("out", 0) for r in rows)
total_reason = sum(r.get("reason", 0) for r in rows)
total_wall   = sum(r.get("wall", 0) for r in rows)

by_model = {}
for r in rows:
    m = r.get("model", "?")
    d = by_model.setdefault(m, {"calls": 0, "tokens": 0})
    d["calls"]  += 1
    d["tokens"] += r.get("prompt", 0) + r.get("out", 0) + r.get("reason", 0)

by_exit = {}
for r in rows:
    code = r.get("exit", 0)
    label = {0: "ok", 5: "NEEDS_SMART", 3: "rate-limit (429)", 2: "api error", 4: "no blocks parsed"}.get(code, f"exit {code}")
    by_exit[label] = by_exit.get(label, 0) + 1

total_tokens = total_prompt + total_out + total_reason
date_label = first_dt.date().isoformat() if first_dt else "?"

print()
print("maestrode gain")
print(f"  since {date_label}{span_days} ({total_calls} call{'s' if total_calls != 1 else ''})")
print()
print(f"  muscle handled:")
print(f"    {human(total_tokens)} tokens  ({human(total_prompt)} prompt / {human(total_out)} output / {human(total_reason)} reasoning)")
print()
print(f"  by model:")
for m, d in sorted(by_model.items(), key=lambda kv: -kv[1]["tokens"]):
    print(f"    {m:<22} {d['calls']:>3} calls  {human(d['tokens']):>6} tokens")
print()
if len(by_exit) > 1 or "ok" not in by_exit:
    print(f"  by exit:")
    for label, count in sorted(by_exit.items(), key=lambda kv: -kv[1]):
        print(f"    {label:<22} {count}")
    print()
avg = total_wall / total_calls if total_calls else 0
print(f"  wall time: {hms(total_wall)} total (avg {hms(avg)}/call)")
print()
sys.exit(0)
PY
  exit $?
fi

: "${MAESTRODE_API_KEY:?set MAESTRODE_API_KEY in ${ENV_FILE} or env}"
MODEL="${MAESTRODE_MODEL:-deepseek-v4-flash}"
ENDPOINT="${MAESTRODE_ENDPOINT:-https://api.deepseek.com/v1/chat/completions}"
MAX_TOKENS="${MAESTRODE_MAX_TOKENS:-65536}"

FULL=0
RAW=0
DRY_RUN=0
WARMUP=0
FILES_DIR=""
SESSION=""
SYSTEM=""
REASONING_EFFORT=""
THINKING_BUDGET=""
USER_FILES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --full)        FULL=1; shift ;;
    --raw)         RAW=1; shift ;;
    --dry-run)     DRY_RUN=1; shift ;;
    --warmup)      WARMUP=1; shift ;;
    --reasoning-effort) REASONING_EFFORT="$2"; shift 2 ;;
    --thinking-budget)  THINKING_BUDGET="$2"; shift 2 ;;
    --model)       MODEL="$2"; shift 2 ;;
    --max-tokens)  MAX_TOKENS="$2"; shift 2 ;;
    --files)       FILES_DIR="$2"; shift 2 ;;
    --session)     SESSION="$2"; shift 2 ;;
    --system)      SYSTEM="$2"; shift 2 ;;
    -f|--file)     USER_FILES+=("$2"); shift 2 ;;
    -h|--help)
      sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    --) shift; break ;;
    -*) echo "maestrode: unknown flag $1" >&2; exit 64 ;;
    *)  break ;;
  esac
done

TASK="${1:-}"

PROMPT_FILE=$(mktemp -t maestrode_prompt.XXXXXX)
PAYLOAD_FILE=$(mktemp -t maestrode_payload.XXXXXX)
RESP_FILE=$(mktemp -t maestrode_resp.XXXXXX)
trap 'rm -f "$PROMPT_FILE" "$PAYLOAD_FILE" "$RESP_FILE"' EXIT

{
  # Only read stdin when it is a real piped/redirected/heredoc input. A bare
  # `[[ ! -t 0 ]]` matches Claude Code's Bash tool, which hands the child a
  # unix-socket stdin that never closes; `cat` would block until the tool
  # killed it (SIGKILL skips the EXIT trap, leaving 0-byte temps and no
  # usage-log write). FIFOs (echo x | ...) and regular files (< file or
  # heredocs that bash backs with a temp file) cover all real-input modes.
  if [[ -p /dev/stdin || -f /dev/stdin ]]; then
    cat
    printf '\n\n'
  fi
  [[ -n "$TASK" ]] && printf '%s\n' "$TASK"
  if [[ ${#USER_FILES[@]} -gt 0 ]]; then
    for f in "${USER_FILES[@]}"; do
      if [[ ! -f "$f" ]]; then
        echo "maestrode: file not found: $f" >&2
        exit 66
      fi
      printf '\n<<<FILE: %s>>>\n' "$f"
      cat "$f"
      printf '\n<<<END FILE>>>\n'
    done
  fi
} > "$PROMPT_FILE"

if [[ ! -s "$PROMPT_FILE" ]] || [[ -z "$(tr -d '[:space:]' < "$PROMPT_FILE")" ]]; then
  echo "maestrode: empty prompt" >&2
  exit 64
fi

if [[ "${MAESTRODE_ALLOW_SECRETS:-0}" != "1" ]]; then
  SECRET_HITS=$(python3 - "$PROMPT_FILE" <<'PY'
import re, sys, pathlib
patterns = [
    (r'\bsk-[A-Za-z0-9_-]{20,}', 'API key (sk-...)'),
    (r'\bAKIA[0-9A-Z]{16}\b', 'AWS access key id'),
    (r'\bASIA[0-9A-Z]{16}\b', 'AWS STS key'),
    (r'\bxoxb-[A-Za-z0-9-]{10,}', 'Slack bot token'),
    (r'\bghp_[A-Za-z0-9]{20,}', 'GitHub PAT'),
    (r'\bgithub_pat_[A-Za-z0-9_]{20,}', 'GitHub fine-grained PAT'),
    (r'-----BEGIN [A-Z ]*PRIVATE KEY-----', 'Private key'),
    (r'\bAIza[0-9A-Za-z_-]{30,}', 'Google API key'),
]
text = pathlib.Path(sys.argv[1]).read_text()
for pat, label in patterns:
    m = re.search(pat, text)
    if m:
        snip = m.group(0)
        snip = snip[:8] + '...' + snip[-4:] if len(snip) > 16 else snip
        print(f"{label}: {snip}")
PY
)
  if [[ -n "$SECRET_HITS" ]]; then
    echo "maestrode: refusing to send prompt that looks like it contains secrets:" >&2
    echo "$SECRET_HITS" >&2
    echo "(set MAESTRODE_ALLOW_SECRETS=1 to override)" >&2
    exit 65
  fi
fi

SESSION_DIR="${CONFIG_DIR}/sessions"
SESSION_FILE=""
if [[ -n "$SESSION" ]]; then
  mkdir -p "$SESSION_DIR"
  SESSION_FILE="$SESSION_DIR/${SESSION}.json"
fi

MODEL="$MODEL" MAX_TOKENS="$MAX_TOKENS" SYSTEM="$SYSTEM" \
SESSION_FILE="$SESSION_FILE" \
REASONING_EFFORT="$REASONING_EFFORT" THINKING_BUDGET="$THINKING_BUDGET" \
python3 - "$PROMPT_FILE" "$PAYLOAD_FILE" <<'PY'
import json, os, sys
user_msg = open(sys.argv[1]).read()
messages = []
session_file = os.environ.get("SESSION_FILE") or ""
if session_file and os.path.exists(session_file):
    messages = json.load(open(session_file))
sysmsg = os.environ.get("SYSTEM") or ""
if sysmsg:
    if messages and messages[0].get("role") == "system":
        messages[0]["content"] = sysmsg
    else:
        messages.insert(0, {"role": "system", "content": sysmsg})
messages.append({"role": "user", "content": user_msg})
payload = {
    "model": os.environ["MODEL"],
    "max_tokens": int(os.environ["MAX_TOKENS"]),
    "messages": messages,
}
re_effort = os.environ.get("REASONING_EFFORT") or ""
if re_effort:
    payload["reasoning_effort"] = re_effort
tb = os.environ.get("THINKING_BUDGET") or ""
if tb:
    payload["thinking"] = {"type": "enabled", "budget_tokens": int(tb)}
open(sys.argv[2], "w").write(json.dumps(payload))
PY

if [[ "$WARMUP" == "1" ]]; then
  WARMUP_PAYLOAD=$(mktemp -t maestrode_warm.XXXXXX)
  WARMUP_RESP=$(mktemp -t maestrode_warm_resp.XXXXXX)
  trap 'rm -f "$WARMUP_PAYLOAD" "$WARMUP_RESP" "$PROMPT_FILE" "$PAYLOAD_FILE" "$RESP_FILE"' EXIT
  python3 - "$PAYLOAD_FILE" "$WARMUP_PAYLOAD" <<'PY'
import json, sys
p = json.load(open(sys.argv[1]))
warmup_msgs = list(p["messages"])
if warmup_msgs and warmup_msgs[-1].get("role") == "user":
    warmup_msgs[-1] = {"role":"user","content":"ack"}
p["messages"] = warmup_msgs
p["max_tokens"] = 32
json.dump(p, open(sys.argv[2], "w"))
PY
  curl -sS --max-time "${MAESTRODE_CURL_TIMEOUT:-600}" \
    -o "$WARMUP_RESP" -X POST "$ENDPOINT" \
    -H "Authorization: Bearer ${MAESTRODE_API_KEY}" \
    -H "Content-Type: application/json" \
    --data-binary "@$WARMUP_PAYLOAD" >/dev/null 2>&1 || true
  sys_cached=$(python3 -c "
import json, sys
try:
  d = json.load(open(sys.argv[1]))
  u = d.get('usage') or {}
  print(u.get('prompt_cache_hit_tokens', 0), u.get('prompt_tokens', 0))
except Exception:
  print(0, 0)
" "$WARMUP_RESP" 2>/dev/null) || sys_cached="0 0"
  echo "[maestrode warmup: prompt=${sys_cached##* } cache=${sys_cached%% *}]" >&2
fi

if [[ "$DRY_RUN" == "1" ]]; then
  python3 - "$PAYLOAD_FILE" <<'PY'
import json, sys, os
p = json.load(open(sys.argv[1]))
total_chars = 0
for m in p["messages"]:
    sys.stderr.write(f"[{m['role']}] {len(m['content'])} chars\n")
    total_chars += len(m["content"])
approx_tokens = total_chars // 4
sys.stderr.write(f"[total] {total_chars} chars, ~{approx_tokens} tokens, max_tokens={p['max_tokens']}, model={p['model']}\n")
sys.stderr.write(f"[dry-run] no request sent\n")
PY
  exit 0
fi

MAX_RETRIES="${MAESTRODE_MAX_RETRIES:-3}"
if [[ "${MAESTRODE_NO_RETRY:-0}" == "1" ]]; then
  MAX_RETRIES=0
fi

CALL_T0=$(python3 -c 'import time; print(time.time())')

attempt=0
backoff=2
HTTP_CODE=""
while true; do
  HTTP_CODE=$(curl -sS --max-time "${MAESTRODE_CURL_TIMEOUT:-600}" \
    -o "$RESP_FILE" -w '%{http_code}' \
    -X POST "$ENDPOINT" \
    -H "Authorization: Bearer ${MAESTRODE_API_KEY}" \
    -H "Content-Type: application/json" \
    --data-binary "@$PAYLOAD_FILE") || {
      echo "maestrode: curl failed" >&2
      [[ -s "$RESP_FILE" ]] && cat "$RESP_FILE" >&2
      exit 1
    }
  if [[ "$HTTP_CODE" == "429" || "$HTTP_CODE" == "503" || "$HTTP_CODE" == "502" ]]; then
    if [[ $attempt -ge $MAX_RETRIES ]]; then
      echo "maestrode: $HTTP_CODE after $MAX_RETRIES retries" >&2
      cat "$RESP_FILE" >&2; echo >&2
      [[ "$HTTP_CODE" == "429" ]] && exit 3 || exit 2
    fi
    jitter=$(( RANDOM % 1000 ))
    sleep_s=$(python3 -c "print($backoff + $jitter/1000)" 2>/dev/null || echo "$backoff")
    echo "maestrode: $HTTP_CODE, retry $((attempt+1))/$MAX_RETRIES after ${sleep_s}s" >&2
    sleep "$sleep_s"
    attempt=$((attempt+1))
    backoff=$((backoff*2))
    continue
  fi
  break
done

if [[ "$HTTP_CODE" != "200" ]]; then
  echo "maestrode: http $HTTP_CODE" >&2
  cat "$RESP_FILE" >&2; echo >&2
  exit 2
fi

FULL="$FULL" RAW="$RAW" FILES_DIR="$FILES_DIR" \
PROMPT_FILE="$PROMPT_FILE" SESSION_FILE="$SESSION_FILE" \
USAGE_LOG="$USAGE_LOG" CALL_T0="$CALL_T0" \
python3 - "$RESP_FILE" <<'PY'
import json, os, sys, re, pathlib

resp = json.load(open(sys.argv[1]))
if "error" in resp:
    sys.stderr.write(f"maestrode api err: {json.dumps(resp['error'])}\n")
    sys.exit(2)
try:
    choice = resp["choices"][0]
    m = choice["message"]
except (KeyError, IndexError):
    sys.stderr.write(f"maestrode: unexpected response shape\n")
    sys.exit(2)

content = m.get("content") or ""
reasoning = m.get("reasoning_content") or ""
finish = choice.get("finish_reason") or ""

# Self-report escalation: if the muscle decides the task exceeds its capability
# or the brief is too ambiguous, it emits <<<NEEDS_SMART>>> (optionally with a
# rationale) as the FIRST non-empty line. Exit 5 so the brain can fall back to
# direct authoring. Checked before session write and --files parse so a clean
# session is preserved and no partial files are written.
first_line = ""
for ln in content.lstrip().splitlines():
    s = ln.strip()
    if s:
        first_line = s
        break
esc = re.match(r'<<<\s*NEEDS_SMART\s*(?::\s*(.*?))?\s*>>>\s*$', first_line)
if esc:
    why = (esc.group(1) or "").strip() or "(no reason given)"
    sys.stderr.write(f"maestrode: muscle escalated. reason: {why}\n")
    sys.stderr.write("hint: handle this turn with the smart model directly.\n")
    # Log the escalation so `maestrode gain` reflects it.
    usage_log = os.environ.get("USAGE_LOG") or ""
    if usage_log:
        import datetime, time
        u = resp.get("usage") or {}
        ct = u.get("completion_tokens") or 0
        rt_ = (u.get("completion_tokens_details") or {}).get("reasoning_tokens") or 0
        pt_ = u.get("prompt_tokens") or 0
        out_ = ct - rt_ if isinstance(ct, int) else 0
        hit_ = u.get("prompt_cache_hit_tokens", 0)
        miss_ = u.get("prompt_cache_miss_tokens", 0)
        t0 = float(os.environ.get("CALL_T0") or 0) or time.time()
        wall = max(0.0, time.time() - t0)
        record = {
            "ts": datetime.datetime.now().isoformat(timespec="seconds"),
            "model": resp.get("model") or "",
            "prompt": pt_, "out": out_, "reason": rt_,
            "cache_hit": hit_, "cache_miss": miss_,
            "finish": choice.get("finish_reason") or "stop",
            "wall": round(wall, 2), "files": 0, "exit": 5,
        }
        try:
            log_path = pathlib.Path(usage_log)
            log_path.parent.mkdir(parents=True, exist_ok=True)
            with log_path.open("a") as f:
                f.write(json.dumps(record) + "\n")
        except OSError:
            pass
    sys.exit(5)

if os.environ.get("RAW") != "1":
    c = content.strip()
    c = re.sub(r'^```[a-zA-Z0-9_+\-]*\s*\n', '', c)
    c = re.sub(r'\n```\s*$', '', c)
    c = c.replace(chr(0x2014), '-').replace(chr(0x2013), '-')
    content = c

session_file = os.environ.get("SESSION_FILE") or ""
if session_file:
    user_msg = open(os.environ["PROMPT_FILE"]).read()
    messages = []
    if os.path.exists(session_file):
        messages = json.load(open(session_file))
    if not messages or messages[-1].get("role") != "user" or messages[-1].get("content") != user_msg:
        messages.append({"role": "user", "content": user_msg})
    messages.append({"role": "assistant", "content": content})
    pathlib.Path(session_file).parent.mkdir(parents=True, exist_ok=True)
    open(session_file, "w").write(json.dumps(messages, indent=2))

files_written = []
files_dir = os.environ.get("FILES_DIR") or ""
if files_dir:
    pat = re.compile(
        r'<<<\s*FILE:\s*(?P<path>[^\n>]+?)\s*>>>\s*\n(?P<body>.*?)\s*<<<\s*END\s*(?:FILE)?\s*>>>',
        re.DOTALL,
    )
    base = pathlib.Path(files_dir)
    base.mkdir(parents=True, exist_ok=True)
    matches = list(pat.finditer(content))
    for mm in matches:
        rel = mm.group("path").strip().lstrip("/")
        parts = pathlib.PurePosixPath(rel).parts
        if ".." in parts or any(p.startswith("/") for p in parts):
            sys.stderr.write(f"maestrode: refused unsafe path {rel}\n")
            continue
        body = mm.group("body")
        body = re.sub(r'^```[a-zA-Z0-9_+\-]*\s*\n', '', body)
        body = re.sub(r'\n```\s*$', '', body)
        target = base / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        if not body.endswith("\n"):
            body += "\n"
        target.write_text(body)
        files_written.append(str(target))
    # Truncation diagnostic: count open markers vs successful (open+close) pairs.
    # finditer only matches closed blocks, so any excess opens were cut off.
    opened = len(re.findall(r'<<<\s*FILE:', content))
    unclosed = opened - len(matches)
    if unclosed > 0:
        sys.stderr.write(
            f"maestrode: {unclosed} <<<FILE:>>> block(s) opened but not closed. "
            f"response looks truncated; retry with --max-tokens higher "
            f"or split the task.\n"
        )
    if not files_written:
        sys.stderr.write("maestrode: --files set but no <<<FILE: ... >>> blocks found\n")
        sys.exit(4)

if os.environ.get("FULL") == "1" and reasoning:
    sys.stdout.write("----- reasoning -----\n")
    sys.stdout.write(reasoning.rstrip() + "\n")
    sys.stdout.write("----- end reasoning -----\n\n")
sys.stdout.write(content.rstrip() + "\n")

u = resp.get("usage") or {}
ct = u.get("completion_tokens") or 0
rt = (u.get("completion_tokens_details") or {}).get("reasoning_tokens") or 0
pt = u.get("prompt_tokens")
out_t = ct - rt if isinstance(ct, int) else "?"
hit = u.get("prompt_cache_hit_tokens", 0)
miss = u.get("prompt_cache_miss_tokens", 0)
cache_str = ""
if (hit or miss) and pt:
    hit_pct = round(100 * (hit or 0) / pt) if pt else 0
    cache_str = f" cache={hit}/{pt}({hit_pct}%)"
finish_str = f" finish={finish}" if finish and finish != "stop" else ""
sys.stderr.write(f"[maestrode model={resp.get('model')} prompt={pt} reason={rt} out={out_t}{cache_str}{finish_str}]\n")
if finish == "length":
    sys.stderr.write("maestrode: response cut by max_tokens. raise --max-tokens (or MAESTRODE_MAX_TOKENS).\n")
if files_written:
    sys.stderr.write(f"[maestrode wrote {len(files_written)} files to {files_dir}]\n")
    for f in files_written:
        sys.stderr.write(f"  + {f}\n")

# Append a usage record to the log so `maestrode gain` can aggregate.
usage_log = os.environ.get("USAGE_LOG") or ""
