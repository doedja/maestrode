#!/usr/bin/env bash
# maestrode: shim that lets a smart model orchestrate a cheap one for code work.
#
# Reads from OpenAI-compatible Chat Completions OR Anthropic Messages endpoints.
# Protocol is auto-picked from the endpoint path: a URL ending in /messages
# speaks the Anthropic Messages API (e.g. OpenCode Zen's minimax/qwen models via
# @ai-sdk/anthropic), everything else speaks OpenAI Chat Completions. Defaults
# are tuned for DeepSeek V4 Flash, but it works against OpenRouter, OmniRoute,
# OpenCode Zen, ollama, lmstudio, or the official DeepSeek/Anthropic APIs.
#
# usage:
#   maestrode "prompt"
#   echo "context" | maestrode "task"
#   maestrode -f a.py -f b.py "refactor both"
#   maestrode --files out/ "spec... write files as <<<FILE: path >>> ... <<<END FILE>>> blocks"
#   maestrode --session arm-b --system "You are a senior engineer." "follow-up turn"
#   maestrode --full "include reasoning trace"
#   maestrode --model gpt-5.1-codex "swap model"
#   maestrode gain                 show aggregate usage stats from the local log
#   maestrode hook <event>         Claude Code persistence hook (stdin JSON);
#                                  event in: user-prompt, pre-tool, session-end
#
# mode profiles (model-agnostic; deployment sets the models via env):
#   (default)         NORMAL muscle: text-block --files drafting (MAESTRODE_MODEL).
#   --ultra           ULTRA muscle: agentic write_file tool loop + reasoning off
#                     (MAESTRODE_ULTRA_MODEL). Implies --tools; needs --files.
#                     For tool-native models (kimi, minimax) on gnarly tasks.
#   --brain           planning call: a reasoning model emits a plan, not files
#                     (MAESTRODE_BRAIN_MODEL). Reasons into the plan text; set
#                     MAESTRODE_BRAIN_THINK=1 to use a separate thinking channel.
#
# flags:
#   --session NAME    persist multi-turn at ~/.config/maestrode/sessions/NAME.json
#   --system TEXT     system prompt
#   --files DIR       parse <<<FILE: path >>> ... <<<END FILE>>> blocks, write each under DIR
#   --tools           agentic write_file tool loop (instead of text blocks). The
#                     muscle calls a real write_file tool; for tool-native models
#                     that ramble past text-block formatting. Implied by --ultra.
#   -f|--file PATH    attach file contents as user context (repeatable)
#   --model ID        override the profile/MAESTRODE_MODEL
#   --endpoint URL    override the profile/MAESTRODE_ENDPOINT
#   --max-tokens N    override max_tokens
#   --reasoning-effort LEVEL   low|medium|high|max (OpenAI path; provider-dependent)
#   --think                    enable thinking (Anthropic path). type=adaptive for
#                              MiniMax/zen; pairs with --full to show the trace
#   --thinking-type T          adaptive|disabled (MiniMax) or enabled (Anthropic)
#   --thinking-budget N        Anthropic extended thinking: type=enabled, budget=N
#   --full            also print reasoning_content
#   --raw             skip auto fence/dash sanitization
#   --dry-run         print payload size estimate, no API call
#   --warmup          send a small priming call first to crystallize KV-cache prefix
#                     (use on a fresh --session before the first real call)
#
# escalation contract (NEEDS_SMART):
#   the muscle can self-report when a brief is too vague or a task exceeds
#   its capability by emitting `<<<NEEDS_SMART>>>` or `<<<NEEDS_SMART: reason>>>`
#   as the first non-empty line of its response. maestrode exits 5 and prints
#   the rationale to stderr. session log + --files writes are skipped so the
#   brain can rerun the turn directly without polluting state.
#   teach the muscle about this contract via --system, e.g.:
#     --system "if the brief is ambiguous or the task exceeds your capability,
#               emit <<<NEEDS_SMART: short reason>>> as line 1 and stop."
#
# env (from ~/.config/maestrode/env or shell):
#   MAESTRODE_API_KEY        required
#   MAESTRODE_MODEL          normal muscle; default: deepseek-v4-flash
#   MAESTRODE_ENDPOINT       normal muscle endpoint; default: api.deepseek.com/.../chat/completions
#   MAESTRODE_MAX_TOKENS     default: 256000 (lower if your endpoint caps shorter)
#   MAESTRODE_ULTRA_MODEL    --ultra muscle (fallback: MAESTRODE_MODEL)
#   MAESTRODE_ULTRA_ENDPOINT --ultra endpoint (fallback: MAESTRODE_ENDPOINT)
#   MAESTRODE_ULTRA_REASONING --ultra reasoning_effort; default: none
#   MAESTRODE_ULTRA_MAX_TOKENS --ultra output reservation; default: 32000. (The
#                            256000 normal default reserves nearly a whole 262144
#                            context, so input + output 400s the provider.)
#   MAESTRODE_BRAIN_MODEL    --brain planner (fallback: MAESTRODE_MODEL)
#   MAESTRODE_BRAIN_ENDPOINT --brain endpoint (fallback: MAESTRODE_ENDPOINT)
#   MAESTRODE_BRAIN_THINK    set 1 to give the brain a separate thinking channel
#   MAESTRODE_BRAIN_THINKING_TYPE  force the brain's thinking.type (anthropic path):
#                            disabled|adaptive|enabled. Use "disabled" for models
#                            like MiniMax-M3 that otherwise reason in a hidden
#                            channel until the window closes (empty-plan stall).
#                            A CLI --think/--thinking-type/--thinking-budget wins.
#   MAESTRODE_CONTEXT_LIMIT  model context window. When set, max_tokens is clamped
#                            to (limit - est_input - margin) so the output
#                            reservation never overshoots the window. Per-mode:
#                            MAESTRODE_ULTRA_CONTEXT_LIMIT / MAESTRODE_BRAIN_CONTEXT_LIMIT.
#   MAESTRODE_CONTEXT_MARGIN headroom left for the clamp; default: 1024 tokens
#   MAESTRODE_PROTOCOL       openai|anthropic; default auto from endpoint path
#   MAESTRODE_CURL_TIMEOUT   default: 600 (seconds)
#   MAESTRODE_ALLOW_SECRETS  set to 1 to bypass the secret-pattern scan
#
# exit codes:
#   0 ok, 1 transport error, 2 api error, 3 rate limit (429),
#   4 --files parse: no blocks found, 5 muscle escalated (NEEDS_SMART),
#   6 empty output (out=0): model produced no content,
#   64 usage, 65 secrets detected, 66 file not found

set -euo pipefail

CONFIG_DIR="${MAESTRODE_CONFIG_DIR:-${HOME}/.config/maestrode}"
ENV_FILE="${CONFIG_DIR}/env"
USAGE_LOG="${CONFIG_DIR}/usage.jsonl"
# Load env file as DEFAULTS: a var already set in the caller's environment
# (e.g. `MAESTRODE_ENDPOINT=... maestrode ...`) wins over the file. Sourcing
# with `. "$ENV_FILE"` would instead clobber caller overrides, so apply each
# KEY=VALUE only when KEY is unset.
if [[ -f "$ENV_FILE" ]]; then
  while IFS='=' read -r _k _v; do
    [[ "$_k" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
    [[ -z "${!_k:-}" ]] && export "$_k=$_v"
  done < "$ENV_FILE"
  unset _k _v
fi

# Subcommand: `maestrode gain` prints aggregate stats from the usage log.
# No API key needed for this path.
if [[ "${1:-}" == "gain" ]]; then
  shift
  USAGE_LOG="$USAGE_LOG" python3 - "$@" <<'PY'
import json, os, sys, datetime, pathlib

log = pathlib.Path(os.environ["USAGE_LOG"])
if not log.exists() or log.stat().st_size == 0:
    print("maestrode gain: no usage logged yet at", log)
    print("(usage logs are appended after each successful call)")
    sys.exit(0)

rows = []
for line in log.read_text().splitlines():
    line = line.strip()
    if not line:
        continue
    try:
        rows.append(json.loads(line))
    except json.JSONDecodeError:
        continue

if not rows:
    print("maestrode gain: usage log exists but no valid entries")
    sys.exit(0)

def human(n: int) -> str:
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n/1_000:.0f}k"
    return str(n)

def hms(s: float) -> str:
    s = int(s)
    if s < 60:
        return f"{s}s"
    m, s = divmod(s, 60)
    if m < 60:
        return f"{m}m {s:02d}s"
    h, m = divmod(m, 60)
    return f"{h}h {m:02d}m {s:02d}s"

first_ts = min(r.get("ts", "") for r in rows if r.get("ts"))
last_ts  = max(r.get("ts", "") for r in rows if r.get("ts"))
def parse_ts(s):
    try:
        return datetime.datetime.fromisoformat(s)
    except Exception:
        return None
first_dt, last_dt = parse_ts(first_ts), parse_ts(last_ts)
span_days = ""
if first_dt and last_dt:
    days = max(1, (last_dt - first_dt).days + 1)
    span_days = f" ({days} day{'s' if days != 1 else ''})"

total_calls = len(rows)
total_prompt = sum(r.get("prompt", 0) for r in rows)
total_out    = sum(r.get("out", 0) for r in rows)
total_reason = sum(r.get("reason", 0) for r in rows)
total_wall   = sum(r.get("wall", 0) for r in rows)

by_model = {}
for r in rows:
    m = r.get("model", "?")
    d = by_model.setdefault(m, {"calls": 0, "tokens": 0})
    d["calls"]  += 1
    d["tokens"] += r.get("prompt", 0) + r.get("out", 0) + r.get("reason", 0)

by_exit = {}
for r in rows:
    code = r.get("exit", 0)
    label = {0: "ok", 5: "NEEDS_SMART", 3: "rate-limit (429)", 2: "api error", 4: "no blocks parsed"}.get(code, f"exit {code}")
    by_exit[label] = by_exit.get(label, 0) + 1

total_tokens = total_prompt + total_out + total_reason
date_label = first_dt.date().isoformat() if first_dt else "?"

print()
print("maestrode gain")
print(f"  since {date_label}{span_days} ({total_calls} call{'s' if total_calls != 1 else ''})")
print()
print(f"  muscle handled:")
print(f"    {human(total_tokens)} tokens  ({human(total_prompt)} prompt / {human(total_out)} output / {human(total_reason)} reasoning)")
print()
print(f"  by model:")
for m, d in sorted(by_model.items(), key=lambda kv: -kv[1]["tokens"]):
    print(f"    {m:<22} {d['calls']:>3} calls  {human(d['tokens']):>6} tokens")
print()
if len(by_exit) > 1 or "ok" not in by_exit:
    print(f"  by exit:")
    for label, count in sorted(by_exit.items(), key=lambda kv: -kv[1]):
        print(f"    {label:<22} {count}")
    print()
avg = total_wall / total_calls if total_calls else 0
print(f"  wall time: {hms(total_wall)} total (avg {hms(avg)}/call)")
print()
sys.exit(0)
PY
  exit $?
fi

# Subcommand: `maestrode hook <event>` drives the Claude Code persistence hooks.
# Reads the hook JSON payload from stdin, keys all state to session_id, and
# prints the hook output JSON to stdout. No API key, no network.
#
# Events:
#   user-prompt   UserPromptSubmit: capture activation/deactivation from the
#                 user's words, inject the standing banner every turn while
#                 active, escalate on drift, reap stale sessions.
#   pre-tool      PreToolUse: record real muscle calls (Bash `maestrode ...`),
#                 nudge on cold direct edits and on subagent (Task) spawns.
#   session-end   SessionEnd: remove this session's state files.
#
# State lives under ${CONFIG_DIR}/sessions/, one set of files per session_id:
#   <sid>            exists => mode active (mtime = activation time)
#   <sid>.lastcall   mtime/contents = last real muscle delegation
#   <sid>.direct     count of cold direct edits since the last delegation
#
# Keyed by session_id so state cannot leak across sessions: a new session has a
# new id and never sees another session's flag. This is the fix for the old
# global ~/.config/maestrode/active sentinel that leaked the mode forward.
if [[ "${1:-}" == "hook" ]]; then
  shift
  # Slurp the hook JSON payload from stdin into a var FIRST, then feed the
  # program to python via a normal `- <<HEREDOC`. python reads the payload from
  # the env var, not stdin (the `-` heredoc form would otherwise shadow it).
  # This avoids heredoc-inside-$()-command-substitution, which macOS bash 3.2
  # mis-parses.
  MAESTRODE_HOOK_PAYLOAD="$(cat)" \
  MAESTRODE_HOOK_EVENT="${1:-}" \
  MAESTRODE_SESSIONS_DIR="${CONFIG_DIR}/sessions" \
  python3 - <<'PY'
import json, os, re, sys, time, pathlib

event = os.environ.get("MAESTRODE_HOOK_EVENT", "")
sessions_dir = pathlib.Path(os.environ["MAESTRODE_SESSIONS_DIR"])

try:
    payload = json.loads(os.environ.get("MAESTRODE_HOOK_PAYLOAD") or "{}")
except Exception:
    payload = {}

sid = payload.get("session_id") or ""
safe = re.sub(r"[^A-Za-z0-9_.-]", "_", sid) if sid else ""

BANNER = (
    "Default for any code, prose, or config draft this turn: delegate to the "
    "muscle:  maestrode -f <files> --files out/ \"<brief>\". Direct Edit/Write "
    "only to apply muscle output, for a one-line tweak, or for an "
    "architecture/security call you must own (say which). Spawning a subagent? "
    "It will NOT inherit this mode: embed the delegation contract in its prompt, "
    "or let the muscle draft directly."
)

# Three modes (Claude Code only). normal: opus plans, muscle drafts. high:
# brain model plans, muscle drafts, opus audits. ultra: brain plans, premium
# tool muscle drafts, opus audits + spec-tests. Check ultra > high > normal.
MODE_ULTRA = re.compile(r"\bmaestrode\s+ultra\b", re.I)
MODE_HIGH = re.compile(r"\bmaestrode\s+high\b", re.I)
ACTIVATE = re.compile(
    r"(?:^|\b)(?:/maestrode\b|maestrode\s+(?:on|mode|normal)\b|use\s+maestrode\b"
    r"|turn\s+on\s+maestrode\b|enable\s+maestrode\b)", re.I)
DEACTIVATE = re.compile(
    r"\b(?:maestrode\s+off|stop\s+maestrode|turn\s+off\s+maestrode"
    r"|disable\s+maestrode)\b", re.I)

def sfile(suffix=""):
    return sessions_dir / (safe + suffix)

def is_active():
    return bool(safe) and sfile().exists()

VALID_MODES = ("normal", "high", "ultra")

def set_mode(mode):
    # session file stores "<mode>\n<activation-ts>". Legacy files held just a ts.
    sfile().write_text(mode + "\n" + str(time.time()))

def get_mode():
    try:
        first = sfile().read_text().splitlines()[0].strip()
    except (OSError, IndexError):
        return "normal"
    return first if first in VALID_MODES else "normal"

def banner_for(mode):
    if mode == "ultra":
        return (
            "[maestrode ULTRA] Brain offloaded + premium tool muscle. Per task: "
            "(1) PLAN: maestrode --brain \"<spec + every edge case>\"  "
            "(2) DRAFT: maestrode --ultra --files out/ \"<implement the plan>\"  "
            "(3) AUDIT (you): write/run INDEPENDENT spec-tests (never the muscle's "
            "own), fix-loop the muscle on real failures, then apply. Use ultra for "
            "gnarly/algorithmic work where craft matters.")
    if mode == "high":
        return (
            "[maestrode HIGH] Brain offloaded, reliable muscle. Per task: "
            "(1) PLAN: maestrode --brain \"<spec + every edge case>\"  "
            "(2) DRAFT: maestrode --files out/ \"<implement the plan>\"  "
            "(3) AUDIT (you): run tests, fix-loop, apply. Routine bulk work; you "
            "plan nothing and draft nothing, only review.")
    return "[maestrode ON] " + BANNER

def clear_session():
    for suffix in ("", ".lastcall", ".direct"):
        try:
            sfile(suffix).unlink()
        except OSError:
            pass

def read_int(path):
    try:
        return int(path.read_text().strip() or "0")
    except (OSError, ValueError):
        return 0

def reap(days=7):
    cutoff = time.time() - days * 86400
    try:
        for p in sessions_dir.iterdir():
            try:
                if p.stat().st_mtime < cutoff:
                    p.unlink()
            except OSError:
                pass
    except OSError:
        pass

def emit(obj):
    sys.stdout.write(json.dumps(obj))
    sys.exit(0)

def silent():
    # No stdout => the hook is a no-op for this call.
    sys.exit(0)

def ups(msg):
    emit({"hookSpecificOutput": {
        "hookEventName": "UserPromptSubmit",
        "additionalContext": msg,
    }})

def nudge(msg):
    # Advisory only: additionalContext, no permissionDecision, so the user's
    # normal permission flow for the tool is untouched (no auto-approve).
    # NOTE: Claude Code currently logs but does NOT inject PreToolUse
    # additionalContext into the model (bug anthropics/claude-code#19432), so
    # this is forward-compatible and a no-op for the model today. The
    # load-bearing channel is the UserPromptSubmit banner, which re-states the
    # drift count next turn (the `.direct` counter below feeds it). Emitting it
    # anyway costs nothing and starts working once the bug is fixed.
    emit({"hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": msg,
    }})

if not safe:
    # No session_id => cannot key state to a session. No-op (never global).
    silent()

try:
    sessions_dir.mkdir(parents=True, exist_ok=True)
except OSError:
    silent()

if event == "user-prompt":
    reap()
    prompt = payload.get("prompt") or ""
    if DEACTIVATE.search(prompt):
        clear_session()
        ups("[maestrode OFF] Mode deactivated. Resume direct authoring.")
    # mode select: ultra > high > normal. Switching resets the drift counter.
    new_mode = None
    if MODE_ULTRA.search(prompt):
        new_mode = "ultra"
    elif MODE_HIGH.search(prompt):
        new_mode = "high"
    elif ACTIVATE.search(prompt):
        new_mode = "normal"
    if new_mode:
        set_mode(new_mode)
        try:
            sfile(".direct").unlink()
        except OSError:
            pass
        ups(banner_for(new_mode))
    if is_active():
        mode = get_mode()
        n = read_int(sfile(".direct"))
        if n >= 2:
            ups("[maestrode %s, drift] You have bypassed the muscle %d times "
                "(direct edits or subagent spawns) since the last delegation. "
                "Route the next draft through the muscle unless there is a named "
                "reason (apply output, one-line tweak, architecture/security call "
                "you must own)." % (mode.upper(), n))
        ups(banner_for(mode))
    silent()

if event == "pre-tool":
    tool = payload.get("tool_name") or ""
    tin = payload.get("tool_input") or {}
    if tool == "Bash":
        cmd = (tin.get("command") or "").lstrip()
        # A real muscle delegation (not `maestrode hook`/`gain`) resets drift.
        if re.match(r"maestrode\b", cmd) and not re.match(r"maestrode\s+(?:hook|gain)\b", cmd):
            if is_active():
                sfile(".lastcall").write_text(str(time.time()))
                try:
                    sfile(".direct").unlink()
                except OSError:
                    pass
        silent()
    if not is_active():
        silent()
    if tool == "Task":
        # A subagent spawn while in mode is a bypass: count it so the next-turn
        # banner escalation reflects it, same as a cold direct edit.
        sfile(".direct").write_text(str(read_int(sfile(".direct")) + 1))
        nudge("[maestrode] You are spawning a subagent. It runs the expensive "
              "model and will NOT inherit maestrode. Either embed the delegation "
              "contract in its prompt so it routes drafts through `maestrode` via "
              "Bash, or skip the subagent and let the muscle draft directly. "
              "Prefer the direct muscle call for a straight draft.")
    if tool in ("Edit", "Write", "MultiEdit", "NotebookEdit"):
        last = 0.0
        try:
            last = float(sfile(".lastcall").read_text().strip() or "0")
        except (OSError, ValueError):
            last = 0.0
        if time.time() - last > 120:
            sfile(".direct").write_text(str(read_int(sfile(".direct")) + 1))
            nudge("[maestrode] Direct edit while mode is ON and no recent muscle "
                  "call. If this applies muscle output or is a one-line tweak, "
                  "proceed. Otherwise this is a draft the muscle should write: "
                  "maestrode -f <file> --files out/ \"<brief>\".")
        silent()
    silent()

if event == "session-end":
    clear_session()
    silent()

silent()
PY
  exit 0
fi

: "${MAESTRODE_API_KEY:?set MAESTRODE_API_KEY in ${ENV_FILE} or env}"
# Normal (default) muscle profile. --ultra / --brain swap these post-parse.
MODEL="${MAESTRODE_MODEL:-deepseek-v4-flash}"
ENDPOINT="${MAESTRODE_ENDPOINT:-https://api.deepseek.com/v1/chat/completions}"
MAX_TOKENS="${MAESTRODE_MAX_TOKENS:-256000}"
# Protocol + headers are resolved AFTER flag parsing, since --ultra/--brain can
# change ENDPOINT (and the protocol/auth follow the endpoint path).

FULL=0
RAW=0
DRY_RUN=0
WARMUP=0
DIFF="${MAESTRODE_DIFF:-0}"
FILES_DIR=""
SESSION=""
SYSTEM=""
REASONING_EFFORT=""
THINKING_BUDGET=""
THINK="${MAESTRODE_THINK:-}"
THINKING_TYPE="${MAESTRODE_THINKING_TYPE:-}"
TOOLS="${MAESTRODE_TOOLS:-0}"
ULTRA=0
BRAIN=0
MODEL_OVERRIDE=""
ENDPOINT_OVERRIDE=""
USER_FILES=()
# Tracks whether --max-tokens was given on the CLI. An explicit flag always wins;
# without it, --ultra substitutes a context-safe default (see profile block below).
MAX_TOKENS_EXPLICIT=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --full)        FULL=1; shift ;;
    --raw)         RAW=1; shift ;;
    --dry-run)     DRY_RUN=1; shift ;;
    --warmup)      WARMUP=1; shift ;;
    --reasoning-effort) REASONING_EFFORT="$2"; shift 2 ;;
    --thinking-budget)  THINKING_BUDGET="$2"; shift 2 ;;
    --think)            THINK=1; shift ;;
    --thinking-type)    THINKING_TYPE="$2"; shift 2 ;;
    --tools)            TOOLS=1; shift ;;
    --ultra)            ULTRA=1; shift ;;
    --brain)            BRAIN=1; shift ;;
    --model)       MODEL_OVERRIDE="$2"; shift 2 ;;
    --endpoint)    ENDPOINT_OVERRIDE="$2"; shift 2 ;;
    --max-tokens)  MAX_TOKENS="$2"; MAX_TOKENS_EXPLICIT=1; shift 2 ;;
    --files)       FILES_DIR="$2"; shift 2 ;;
    --session)     SESSION="$2"; shift 2 ;;
    --system)      SYSTEM="$2"; shift 2 ;;
    -f|--file)     USER_FILES+=("$2"); shift 2 ;;
    -h|--help)
      sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    --) shift; break ;;
    -*) echo "maestrode: unknown flag $1" >&2; exit 64 ;;
    *)  break ;;
  esac
done

# Resolve the model profile from the mode flag. Profiles are env-driven so the
# shim stays model-agnostic: a deployment sets the BRAIN/ULTRA models it wants.
#   --ultra : ultra muscle (tool-calling, no muscle-side reasoning). The brain
#             already planned, so the muscle implements; reasoning=none keeps
#             tool-native models (kimi) from over-thinking past the tool call.
#   --brain : planning call (a thinking model emits a plan, not files).
#   (none)  : normal muscle (text-block --files drafting).
# Explicit --model/--endpoint/--reasoning-effort flags still override a profile.
if [[ "$ULTRA" == 1 ]]; then
  MODEL="${MAESTRODE_ULTRA_MODEL:-$MODEL}"
  ENDPOINT="${MAESTRODE_ULTRA_ENDPOINT:-$ENDPOINT}"
  TOOLS=1
  [[ -z "$REASONING_EFFORT" ]] && REASONING_EFFORT="${MAESTRODE_ULTRA_REASONING:-none}"
  # The normal-muscle default (256000) reserves nearly a whole 262144-context model
  # for output, so input + max_tokens overshoots the limit and the provider 400s
  # before any work. The ultra muscle writes one file per tool call, so a modest
  # output reservation is plenty. An explicit --max-tokens always wins.
  [[ "$MAX_TOKENS_EXPLICIT" == 0 ]] && MAX_TOKENS="${MAESTRODE_ULTRA_MAX_TOKENS:-32000}"
elif [[ "$BRAIN" == 1 ]]; then
  MODEL="${MAESTRODE_BRAIN_MODEL:-$MODEL}"
  ENDPOINT="${MAESTRODE_BRAIN_ENDPOINT:-$ENDPOINT}"
  # The brain reasons NATIVELY into the plan text. Do NOT divert reasoning into a
  # separate thinking channel by default: adaptive thinking can burn the whole
  # token budget before any plan content is written (finish=length, empty plan).
  # Opt in with MAESTRODE_BRAIN_THINK=1 only if your brain model needs it.
  if [[ "${MAESTRODE_BRAIN_THINK:-0}" == "1" \
