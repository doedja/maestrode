        thinking = {"type": ttype}
        if ttype == "enabled":
            thinking["budget_tokens"] = int(tb or 4000)
        payload["thinking"] = thinking
else:
    if sysmsg:
        messages.insert(0, {"role": "system", "content": sysmsg})
    payload = {
        "model": model,
        "max_tokens": max_tokens,
        "messages": messages,
        "stream": True,
        "stream_options": {"include_usage": True},
    }
    if re_effort:
        payload["reasoning_effort"] = re_effort
    if tb:
        payload["thinking"] = {"type": "enabled", "budget_tokens": int(tb)}
open(sys.argv[2], "w").write(json.dumps(payload))
