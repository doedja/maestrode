# SSE parser: reads streaming chunks on stdin, prints stderr heartbeat,
# and synthesizes a non-streaming-shape JSON to stdout so the downstream
# parser (FULL/RAW/FILES_DIR block) works unchanged. If the response body
# is not SSE (HTTP error JSON), the raw body is passed through.
cat > "$PARSER_FILE" <<'PY'
import json, os, sys, time

proto = os.environ.get("PROTOCOL") or "openai"
content = []
reasoning = []
usage = None
model = None
finish = None
last_hb = time.time()
content_chars = 0
reasoning_chars = 0
saw_sse = False
raw_buf = []
done = False

# Iterate to natural EOF (do NOT break on [DONE]/message_stop). Breaking early
# closes the read end of the curl|python pipe, curl then writes the final bytes
# into a broken pipe and exits 56, which the parent loop misreads as a
# transport failure even though we already have the full response.
for raw in sys.stdin:
    line = raw.rstrip('\n').rstrip('\r')
    # Both protocols are SSE: payload rides on `data:` lines. Anthropic also
    # emits `event:` lines (event type is duplicated inside the data JSON's
    # "type" field, so we dispatch off that and can ignore the event: lines).
    if not line.startswith('data:'):
        if not saw_sse:
            raw_buf.append(raw)
        continue
    saw_sse = True
    payload = line[5:].lstrip()
    if payload == '[DONE]':
        done = True
        continue
    if done:
        continue
    try:
        chunk = json.loads(payload)
    except json.JSONDecodeError:
        continue

    if proto == "anthropic":
        ctype = chunk.get("type")
        if ctype == "error" or chunk.get("error"):
            json.dump(chunk, sys.stdout)
            sys.exit(0)
        if ctype == "message_start":
            msg = chunk.get("message") or {}
            if not model:
                model = msg.get("model")
            usage = dict(msg.get("usage") or {})
        elif ctype == "content_block_delta":
            d = chunk.get("delta") or {}
            dt = d.get("type")
            if dt == "text_delta":
                t = d.get("text") or ""
                if t:
                    content.append(t)
                    content_chars += len(t)
            elif dt == "thinking_delta":
                t = d.get("thinking") or ""
                if t:
                    reasoning.append(t)
                    reasoning_chars += len(t)
        elif ctype == "message_delta":
            d = chunk.get("delta") or {}
            sr = d.get("stop_reason")
            if sr:
                finish = sr
            u = chunk.get("usage") or {}
            if u:
                usage = usage or {}
                usage.update(u)
        elif ctype == "message_stop":
            done = True
    else:
        if chunk.get('error'):
            json.dump(chunk, sys.stdout)
            sys.exit(0)
        if chunk.get('usage'):
            usage = chunk['usage']
        if not model and chunk.get('model'):
            model = chunk['model']
        choices = chunk.get('choices') or []
        if not choices:
            continue
        delta = choices[0].get('delta') or {}
        c = delta.get('content')
        if c:
            content.append(c)
            content_chars += len(c)
        r = delta.get('reasoning_content')
        if r:
            reasoning.append(r)
            reasoning_chars += len(r)
        fr = choices[0].get('finish_reason')
        if fr:
            finish = fr

    now = time.time()
    if now - last_hb >= 1.0:
        if reasoning_chars and not content_chars:
            sys.stderr.write(f"[maestrode streaming reasoning={reasoning_chars}]\n")
        else:
            sys.stderr.write(f"[maestrode streaming content={content_chars} reasoning={reasoning_chars}]\n")
        sys.stderr.flush()
        last_hb = now

if not saw_sse:
    sys.stdout.write(''.join(raw_buf))
    sys.exit(0)

# Normalize to one internal (OpenAI-shaped) response so everything downstream
# (escalation scan, --files, session write, stat line, usage log) is unchanged.
if proto == "anthropic":
    u = usage or {}
    inp = u.get("input_tokens") or 0
    cache_read = u.get("cache_read_input_tokens") or 0
    cache_write = u.get("cache_creation_input_tokens") or 0
    out_tok = u.get("output_tokens") or 0
    sr_map = {"end_turn": "stop", "max_tokens": "length",
              "stop_sequence": "stop", "tool_use": "tool_calls"}
    finish_norm = sr_map.get(finish, finish or "stop")
    out_usage = {
        "prompt_tokens": inp + cache_read + cache_write,
        "completion_tokens": out_tok,
        "completion_tokens_details": {"reasoning_tokens": 0},
        "prompt_cache_hit_tokens": cache_read,
        "prompt_cache_miss_tokens": inp,
    }
else:
    finish_norm = finish or "stop"
    out_usage = usage or {}

out = {
    "model": model or "",
    "choices": [{
        "message": {
            "content": "".join(content),
            "reasoning_content": "".join(reasoning) or None,
        },
        "finish_reason": finish_norm,
    }],
    "usage": out_usage,
}
json.dump(out, sys.stdout)
PY

attempt=0
backoff=2
HTTP_CODE=""
while true; do
  : > "$RESP_FILE"
  : > "$HDRS_FILE"
  set +e
  curl --no-buffer -sS \
    --connect-timeout 10 \
    --speed-time 30 --speed-limit 1 \
    --max-time "${MAESTRODE_CURL_TIMEOUT:-600}" \
    -D "$HDRS_FILE" \
    -X POST "$ENDPOINT" \
    "${CURL_HEADERS[@]}" \
    --data-binary "@$PAYLOAD_FILE" \
    | PROTOCOL="$PROTOCOL" python3 -u "$PARSER_FILE" > "$RESP_FILE"
  CURL_EXIT="${PIPESTATUS[0]}"
  set -e
  HTTP_CODE=$(awk 'NR==1 {print $2; exit}' "$HDRS_FILE" 2>/dev/null || echo "")

  # curl exit 28 = total --max-time hit OR idle abort via --speed-time.
  # Treat as transient and retry with backoff. This is the "stuck for 10 min"
  # fix: --speed-time 30 means a wedged stream dies in 30s, not 600s.
  if [[ "$CURL_EXIT" == "28" ]]; then
    if [[ $attempt -ge $MAX_RETRIES ]]; then
      echo "maestrode: stream stalled (curl exit 28) after $MAX_RETRIES retries" >&2
      exit 1
    fi
    echo "maestrode: stream stalled, retry $((attempt+1))/$MAX_RETRIES after ${backoff}s" >&2
    sleep "$backoff"
    attempt=$((attempt+1))
    backoff=$((backoff*2))
    continue
  fi
  if [[ "$CURL_EXIT" != "0" ]]; then
    echo "maestrode: curl exit $CURL_EXIT" >&2
    [[ -s "$RESP_FILE" ]] && cat "$RESP_FILE" >&2
    exit 1
  fi
  if [[ "$HTTP_CODE" == "429" || "$HTTP_CODE" == "503" || "$HTTP_CODE" == "502" ]]; then
    if [[ $attempt -ge $MAX_RETRIES ]]; then
      echo "maestrode: $HTTP_CODE after $MAX_RETRIES retries" >&2
      cat "$RESP_FILE" >&2; echo >&2
      [[ "$HTTP_CODE" == "429" ]] && exit 3 || exit 2
    fi
    jitter=$(( RANDOM % 1000 ))
    sleep_s=$(python3 -c "print($backoff + $jitter/1000)" 2>/dev/null || echo "$backoff")
    echo "maestrode: $HTTP_CODE, retry $((attempt+1))/$MAX_RETRIES after ${sleep_s}s" >&2
    sleep "$sleep_s"
    attempt=$((attempt+1))
    backoff=$((backoff*2))
    continue
  fi
  break
done

if [[ "$HTTP_CODE" != "200" ]]; then
  echo "maestrode: http $HTTP_CODE" >&2
  cat "$RESP_FILE" >&2; echo >&2
  exit 2
fi

FULL="$FULL" RAW="$RAW" FILES_DIR="$FILES_DIR" \
PROMPT_FILE="$PROMPT_FILE" SESSION_FILE="$SESSION_FILE" \
USAGE_LOG="$USAGE_LOG" CALL_T0="$CALL_T0" \
python3 - "$RESP_FILE" <<'PY'
import json, os, sys, re, pathlib

resp = json.load(open(sys.argv[1]))
if "error" in resp:
    sys.stderr.write(f"maestrode api err: {json.dumps(resp['error'])}\n")
    sys.exit(2)
try:
    choice = resp["choices"][0]
    m = choice["message"]
except (KeyError, IndexError):
    sys.stderr.write(f"maestrode: unexpected response shape\n")
    sys.exit(2)

content = m.get("content") or ""
reasoning = m.get("reasoning_content") or ""
finish = choice.get("finish_reason") or ""

# Some models (minimax-m3, qwen) emit chain-of-thought inline as <think>...</think>
# in the content channel instead of a separate reasoning_content field. Pull those
# blocks out of content so drafted code/prose and --files output never carry them.
# Fold the text into reasoning so --full still surfaces it. Run this BEFORE the
# escalation scan, session write, and --files parse so a <<<NEEDS_SMART>>> marker
# placed after a think block is still seen as the first real line.
_think = re.findall(r'<think(?:ing)?>(.*?)</think(?:ing)?>', content, flags=re.DOTALL | re.IGNORECASE)
content = re.sub(r'<think(?:ing)?>.*?</think(?:ing)?>', '', content, flags=re.DOTALL | re.IGNORECASE)
# A dangling, unclosed <think> means reasoning was truncated (finish=length) with
# no usable content after it. Drop from the open tag through end-of-string.
content = re.sub(r'<think(?:ing)?>(?:(?!</think(?:ing)?>).)*$', '', content, flags=re.DOTALL | re.IGNORECASE)
if _think:
    _extracted = "\n".join(t.strip() for t in _think if t.strip())
    if _extracted:
        reasoning = (reasoning.rstrip() + "\n\n" + _extracted).strip() if reasoning else _extracted
content = content.strip()

# Self-report escalation: if the muscle decides the task exceeds its capability
# or the brief is too ambiguous, it emits <<<NEEDS_SMART>>> (optionally with a
# rationale) as the FIRST non-empty line. Exit 5 so the brain can fall back to
# direct authoring. Checked before session write and --files parse so a clean
# session is preserved and no partial files are written.
first_line = ""
for ln in content.lstrip().splitlines():
    s = ln.strip()
    if s:
        first_line = s
        break
esc = re.match(r'<<<\s*NEEDS_SMART\s*(?::\s*(.*?))?\s*>>>\s*$', first_line)
if esc:
    why = (esc.group(1) or "").strip() or "(no reason given)"
    sys.stderr.write(f"maestrode: muscle escalated. reason: {why}\n")
    sys.stderr.write("hint: handle this turn with the smart model directly.\n")
    # Log the escalation so `maestrode gain` reflects it.
    usage_log = os.environ.get("USAGE_LOG") or ""
    if usage_log:
        import datetime, time
        u = resp.get("usage") or {}
        ct = u.get("completion_tokens") or 0
        rt_ = (u.get("completion_tokens_details") or {}).get("reasoning_tokens") or 0
        pt_ = u.get("prompt_tokens") or 0
        out_ = ct - rt_ if isinstance(ct, int) else 0
        hit_ = u.get("prompt_cache_hit_tokens", 0)
        miss_ = u.get("prompt_cache_miss_tokens", 0)
        t0 = float(os.environ.get("CALL_T0") or 0) or time.time()
        wall = max(0.0, time.time() - t0)
        record = {
            "ts": datetime.datetime.now().isoformat(timespec="seconds"),
            "model": resp.get("model") or "",
            "prompt": pt_, "out": out_, "reason": rt_,
            "cache_hit": hit_, "cache_miss": miss_,
            "finish": choice.get("finish_reason") or "stop",
            "wall": round(wall, 2), "files": 0, "exit": 5,
        }
        try:
            log_path = pathlib.Path(usage_log)
            log_path.parent.mkdir(parents=True, exist_ok=True)
            with log_path.open("a") as f:
                f.write(json.dumps(record) + "\n")
        except OSError:
            pass
    sys.exit(5)

if os.environ.get("RAW") != "1":
    c = content.strip()
    c = re.sub(r'^```[a-zA-Z0-9_+\-]*\s*\n', '', c)
    c = re.sub(r'\n```\s*$', '', c)
    c = c.replace(chr(0x2014), '-').replace(chr(0x2013), '-')
    content = c

session_file = os.environ.get("SESSION_FILE") or ""
if session_file:
    user_msg = open(os.environ["PROMPT_FILE"]).read()
    messages = []
    if os.path.exists(session_file):
        messages = json.load(open(session_file))
    if not messages or messages[-1].get("role") != "user" or messages[-1].get("content") != user_msg:
        messages.append({"role": "user", "content": user_msg})
    messages.append({"role": "assistant", "content": content})
    pathlib.Path(session_file).parent.mkdir(parents=True, exist_ok=True)
    open(session_file, "w").write(json.dumps(messages, indent=2))

files_written = []
files_dir = os.environ.get("FILES_DIR") or ""
if files_dir:
    pat = re.compile(
        r'<<<\s*FILE:\s*(?P<path>[^\n>]+?)\s*>>>\s*\n(?P<body>.*?)\s*<<<\s*END\s*(?:FILE)?\s*>>>',
        re.DOTALL,
    )
    base = pathlib.Path(files_dir)
    base.mkdir(parents=True, exist_ok=True)
    matches = list(pat.finditer(content))
    for mm in matches:
        rel = mm.group("path").strip().lstrip("/")
        parts = pathlib.PurePosixPath(rel).parts
        if ".." in parts or any(p.startswith("/") for p in parts):
            sys.stderr.write(f"maestrode: refused unsafe path {rel}\n")
            continue
        body = mm.group("body")
        body = re.sub(r'^```[a-zA-Z0-9_+\-]*\s*\n', '', body)
        body = re.sub(r'\n```\s*$', '', body)
        target = base / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        if not body.endswith("\n"):
            body += "\n"
        target.write_text(body)
        files_written.append(str(target))
    # Truncation diagnostic: count open markers vs successful (open+close) pairs.
    # finditer only matches closed blocks, so any excess opens were cut off.
    opened = len(re.findall(r'<<<\s*FILE:', content))
    unclosed = opened - len(matches)
    if unclosed > 0:
        sys.stderr.write(
            f"maestrode: {unclosed} <<<FILE:>>> block(s) opened but not closed. "
            f"response looks truncated; retry with --max-tokens higher "
            f"or split the task.\n"
        )
    if not files_written:
        sys.stderr.write("maestrode: --files set but no <<<FILE: ... >>> blocks found\n")
        sys.exit(4)

if os.environ.get("FULL") == "1" and reasoning:
    sys.stdout.write("----- reasoning -----\n")
    sys.stdout.write(reasoning.rstrip() + "\n")
    sys.stdout.write("----- end reasoning -----\n\n")
sys.stdout.write(content.rstrip() + "\n")

u = resp.get("usage") or {}
ct = u.get("completion_tokens") or 0
rt = (u.get("completion_tokens_details") or {}).get("reasoning_tokens") or 0
pt = u.get("prompt_tokens")
out_t = ct - rt if isinstance(ct, int) else "?"
hit = u.get("prompt_cache_hit_tokens", 0)
miss = u.get("prompt_cache_miss_tokens", 0)
cache_str = ""
if (hit or miss) and pt:
    hit_pct = round(100 * (hit or 0) / pt) if pt else 0
    cache_str = f" cache={hit}/{pt}({hit_pct}%)"
finish_str = f" finish={finish}" if finish and finish != "stop" else ""
sys.stderr.write(f"[maestrode model={resp.get('model')} prompt={pt} reason={rt} out={out_t}{cache_str}{finish_str}]\n")
if finish == "length":
    sys.stderr.write("maestrode: response cut by max_tokens. raise --max-tokens (or MAESTRODE_MAX_TOKENS).\n")
if files_written:
    sys.stderr.write(f"[maestrode wrote {len(files_written)} files to {files_dir}]\n")
    for f in files_written:
        sys.stderr.write(f"  + {f}\n")

# Empty output (out=0) on a plain-text call: the model burned the window reasoning
# and emitted no content (the reported MiniMax-M3 stall). Exit 0 here is the trap:
# a 1-byte file looks like success to any caller that only checks the exit code.
# Fail loudly so the brain/caller falls back instead of proceeding on a blank plan.
# (--files calls with no blocks already exit 4 above, so this guards text mode only.)
empty_text = (not files_dir) and (not content.strip())

# Append a usage record to the log so `maestrode gain` can aggregate.
usage_log = os.environ.get("USAGE_LOG") or ""
if usage_log:
    import datetime, time
    t0 = float(os.environ.get("CALL_T0") or 0) or time.time()
    wall = max(0.0, time.time() - t0)
    record = {
        "ts": datetime.datetime.now().isoformat(timespec="seconds"),
        "model": resp.get("model") or "",
        "prompt": pt if isinstance(pt, int) else 0,
        "out": out_t if isinstance(out_t, int) else 0,
        "reason": rt if isinstance(rt, int) else 0,
        "cache_hit": hit if isinstance(hit, int) else 0,
        "cache_miss": miss if isinstance(miss, int) else 0,
        "finish": finish or "stop",
        "wall": round(wall, 2),
        "files": len(files_written),
        "exit": 6 if empty_text else 0,
    }
    try:
        log_path = pathlib.Path(usage_log)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        with log_path.open("a") as f:
            f.write(json.dumps(record) + "\n")
    except OSError:
        pass

if empty_text:
    sys.stderr.write("maestrode: empty output (out=0): model produced no content "
                     "(reasoning stall or window exhausted before writing). exiting 6 "
                     "so callers do not proceed on a blank result.\n")
    sys.exit(6)
PY
